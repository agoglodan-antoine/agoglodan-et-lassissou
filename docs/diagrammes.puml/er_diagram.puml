@startuml er_diagram
!include diagram_style.iuml

top to bottom direction
title Modèle conceptuel de données — vue simplifiée

entity UTILISATEUR {
  * id_utilisateur
  --
  nom
  email
  role
}
entity ANNONCE {
  * id_annonce
  --
  type
  prix
  quantite
  statut
}
entity REDUCTION_ANNONCE {
  * id_reduction
  --
  seuil_quantite
  pourcentage
}
entity COMMANDE {
  * id_commande
  --
  quantite
  montant_net
  mode_retrait
  statut
}
entity PAIEMENT {
  * id_paiement
  --
  total
  moyen
  statut
}
entity LIVRAISON {
  * id_livraison
  --
  statut
  verification_qr
}
entity VERSEMENT {
  * id_versement
  --
  montant
  statut
}
entity SERVICE_VETERINAIRE {
  * id_service
  --
  titre
  prix
}
entity RENDEZ_VOUS {
  * id_rdv
  --
  date_prevue
  statut
}
entity NOTIFICATION {
  * id_notification
  --
  contenu
  lu
}

UTILISATEUR "1,1" -- "0,n" ANNONCE : publie (fournisseur)
ANNONCE "1,1" -- "0,n" REDUCTION_ANNONCE : définit
UTILISATEUR "1,1" -- "0,n" COMMANDE : passe (acheteur)
ANNONCE "1,1" -- "0,n" COMMANDE : concerne
COMMANDE "1,1" -- "0,1" PAIEMENT : règle
COMMANDE "1,1" -- "0,1" LIVRAISON : génère
UTILISATEUR "0,1" -- "0,n" LIVRAISON : assure (livreur)
PAIEMENT "1,1" -- "1,n" VERSEMENT : génère
UTILISATEUR "1,1" -- "0,n" VERSEMENT : bénéficie
UTILISATEUR "1,1" -- "0,n" SERVICE_VETERINAIRE : propose (vétérinaire)
SERVICE_VETERINAIRE "1,1" -- "0,n" RENDEZ_VOUS : concerne
UTILISATEUR "1,1" -- "0,n" RENDEZ_VOUS : demande (éleveur)
UTILISATEUR "1,1" -- "0,n" NOTIFICATION : reçoit

note bottom of LIVRAISON
  Optionnelle : absente si le retrait
  direct a été choisi par l'acheteur.
end note
@enduml
