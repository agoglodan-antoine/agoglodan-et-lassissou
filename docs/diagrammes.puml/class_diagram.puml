@startuml class_diagram
!include diagram_style.iuml

left to right direction
hide empty members
skinparam classAttributeIconSize 0
title Modèle métier d'ElevConnect — vue simplifiée

class Utilisateur {
  id
  nom
  email
  role
}
class Annonce {
  id
  type
  prixUnitaire
  quantite
  statut
}
class ReductionAnnonce {
  quantiteMin
  pourcentage
}
class Commande {
  id
  quantite
  montantNet
  modeRetrait
  statut
}
class Paiement {
  total
  moyen
  statut
}
class Livraison {
  statut
  codeQR
  verification
}
class Versement {
  montant
  beneficiaire
  statut
}
class ServiceVeterinaire {
  titre
  prix
}
class RendezVous {
  datePrevue
  statut
}
class Notification {
  contenu
  lue
}

Utilisateur "1" --> "0..*" Annonce : publie\n[fournisseur]
Annonce "1" *-- "0..*" ReductionAnnonce : propose
Utilisateur "1" --> "0..*" Commande : passe\n[acheteur]
Annonce "1" --> "0..*" Commande : concerne
Commande "1" *-- "0..1" Paiement : règle
Commande "1" *-- "0..1" Livraison : livre\n[optionnel]
Utilisateur "0..1" --> "0..*" Livraison : assure\n[livreur]
Paiement "1" --> "1..*" Versement : déclenche
Utilisateur "1" --> "0..*" ServiceVeterinaire : propose\n[vétérinaire]
ServiceVeterinaire "1" --> "0..*" RendezVous : concerne
Utilisateur "1" --> "0..*" RendezVous : demande\n[éleveur]
Utilisateur "1" --> "0..*" Notification : reçoit

note bottom of Utilisateur
  Rôles : acheteur, éleveur, vendeur, vétérinaire,
  livreur ou administrateur.
end note
note bottom of Livraison
  Créée seulement si l'acheteur choisit
  une livraison plutôt qu'un retrait direct.
end note
@enduml
