@startuml state_commande
!include diagram_style.iuml

title Cycle de vie d'une commande — vue simplifiée

[*] --> EnAttente : création
EnAttente --> Payee : paiement accepté
EnAttente --> Annulee : annulation
Payee --> Traitement : notification fournisseur
Traitement --> Validee : commande acceptée
Traitement --> Refusee : commande refusée
Validee --> EnLivraison : livraison choisie
Validee --> Confirmee : retrait direct confirmé
EnLivraison --> Livree : remise au client
Livree --> Confirmee : QR code validé
Confirmee --> [*] : versements
Annulee --> [*]
Refusee --> [*] : remboursement

state EnAttente as "En attente"
state Payee as "Payée"
state Traitement as "En traitement"
state Validee as "Validée"
state EnLivraison as "En livraison"
state Livree as "Livrée"
state Confirmee as "Confirmée"
state Annulee as "Annulée"
state Refusee as "Refusée"
@enduml
