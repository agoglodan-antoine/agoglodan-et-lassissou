@startuml act_publier_annonce
!include diagram_style.iuml

title Publier une annonce — vue simplifiée

|Fournisseur|
start
:Remplir l'annonce
et le barème de réduction;
|Système ElevConnect|
:Contrôler les informations;
if (Données valides ?) then (oui)
  :Enregistrer l'annonce
« en attente »;
  |Administrateur|
  :Examiner l'annonce;
  if (Annonce conforme ?) then (oui)
    |Système ElevConnect|
    :Rendre l'annonce visible
et notifier le fournisseur;
  else (non)
    |Système ElevConnect|
    :Rejeter l'annonce,
indiquer le motif et notifier;
  endif
else (non)
  |Fournisseur|
  :Corriger les informations;
endif
stop
@enduml
