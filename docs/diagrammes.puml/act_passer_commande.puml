@startuml act_passer_commande
!include diagram_style.iuml

title Passer une commande — vue simplifiée

|Acheteur|
start
:Choisir une annonce,
une quantité et le mode de retrait;
|Système ElevConnect|
:Vérifier le stock et
calculer le montant;
if (Stock disponible ?) then (oui)
  :Créer la commande et
le code QR d'authenticité;
  |Acheteur|
  :Payer la commande;
  |Fournisseur|
  :Accepter ou refuser
la commande;
  if (Commande acceptée ?) then (oui)
    |Système ElevConnect|
    if (Livraison choisie ?) then (oui)
      :Proposer la livraison
à un livreur disponible;
      |Livreur|
      :Livrer la commande
et présenter le QR code;
      |Acheteur|
      :Scanner le QR code et
confirmer la réception;
    else (retrait direct)
      |Acheteur|
      :Confirmer la réception
chez le fournisseur;
    endif
    |Système ElevConnect|
    :Confirmer la commande et
verser les bénéficiaires;
    stop
  else (non)
    |Système ElevConnect|
    :Refuser la commande et
rembourser l'acheteur;
    stop
  endif
else (non)
  :Informer l'acheteur que
le stock est indisponible;
  stop
endif
@enduml
