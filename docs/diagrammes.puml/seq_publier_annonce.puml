@startuml seq_publier_annonce
!include diagram_style.iuml

autonumber
actor Fournisseur as FOUR
boundary "Interface web" as UI
control "ElevConnect" as APP
database "Base de données" as DB
actor Administrateur as ADM

title Publication d'une annonce — vue simplifiée

FOUR -> UI : saisit l'annonce
UI -> APP : soumettreAnnonce(données)
APP -> APP : valide les informations
APP -> DB : enregistre « en attente »
APP -> ADM : notifie la modération

ADM -> UI : approuve ou rejette
UI -> APP : modérerAnnonce(décision, motif)
alt annonce approuvée
  APP -> DB : rend l'annonce visible
  APP -> FOUR : notifie la publication
else annonce rejetée
  APP -> DB : enregistre le motif
  APP -> FOUR : notifie le rejet
end
@enduml
