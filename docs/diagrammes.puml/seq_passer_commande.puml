@startuml seq_passer_commande
!include diagram_style.iuml

autonumber
actor Acheteur as ACH
boundary "Interface web" as UI
control "ElevConnect" as APP
database "Base de données" as DB
actor Fournisseur as FOUR
actor Livreur as LIV

title Commande et réception — vue simplifiée

ACH -> UI : choisit l'annonce et le retrait
UI -> APP : créerCommande(annonce, quantité, mode)
APP -> DB : vérifie le stock et enregistre
APP --> UI : affiche le montant à payer

ACH -> UI : paie la commande
UI -> APP : confirmerPaiement()
APP -> DB : commande payée
APP -> FOUR : notifie la commande

FOUR -> UI : accepte la commande
UI -> APP : validerCommande()
APP -> DB : commande validée

alt livraison choisie
  APP -> LIV : propose la livraison
  LIV -> UI : prend en charge et livre
  UI -> APP : confirme la livraison
  ACH -> UI : scanne le QR code
  UI -> APP : confirmerRéception(code)
  APP -> DB : commande confirmée
else retrait direct
  ACH -> UI : confirme la réception
  UI -> APP : confirmerRéception()
  APP -> DB : commande confirmée
end

APP -> DB : crée les versements
APP --> ACH : confirme la commande
@enduml
