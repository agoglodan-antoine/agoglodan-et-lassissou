@startuml state_livraison
!include diagram_style.iuml

title Cycle de vie d'une livraison — vue simplifiée

[*] --> EnAttente : commande validée
EnAttente --> PriseEnCharge : livreur accepte
EnAttente --> NonAssignee : aucun livreur disponible
PriseEnCharge --> EnCours : départ du livreur
EnCours --> AConfirmer : commande remise
AConfirmer --> Terminee : QR code validé
AConfirmer --> Incident : QR code invalide
Terminee --> [*]
NonAssignee --> [*]
Incident --> [*]

state EnAttente as "En attente"
state PriseEnCharge as "Prise en charge"
state EnCours as "En cours"
state AConfirmer as "À confirmer"
state Terminee as "Terminée"
state NonAssignee as "Non assignée"
state Incident as "Incident à traiter"
@enduml
