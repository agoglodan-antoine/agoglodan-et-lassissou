@startuml seq_paiement_versement
!include diagram_style.iuml

autonumber
actor Acheteur as ACH
boundary "Interface web" as UI
control "Service paiement" as PAY
participant "Passerelle de paiement" as GATE
database "Base de données" as DB
actor Fournisseur as FOUR
actor Livreur as LIV

title Paiement, séquestre et versements — vue simplifiée

ACH -> UI : confirme le paiement
UI -> PAY : initierPaiement(commande, moyen)
PAY -> GATE : débiter le total
GATE --> PAY : paiement accepté
PAY -> DB : enregistre le paiement séquestré
PAY -> FOUR : notifie le paiement reçu

note over ACH, LIV
  Le versement intervient après la confirmation
  de la réception de la commande.
end note

ACH -> UI : confirme la réception
UI -> PAY : libérerFonds()
PAY -> DB : confirme la commande
PAY -> GATE : créditer le fournisseur
GATE --> PAY : versement réussi
PAY -> DB : enregistre le versement fournisseur
PAY -> FOUR : notifie le versement

opt une livraison a été effectuée
  PAY -> GATE : créditer le livreur
  GATE --> PAY : versement réussi
  PAY -> DB : enregistre le versement livreur
  PAY -> LIV : notifie le versement
end
@enduml
