@startuml schema_relationnel
' ============================================================
' ElevConnect — Schéma relationnel complet (22 tables) — v4
' Chapitre 4, section II-1
' ============================================================
skinparam backgroundColor #FFFFFF
skinparam roundcorner 6
skinparam shadowing false
skinparam linetype ortho

skinparam entity {
  BackgroundColor #FBF8F2
  BorderColor #234D2E
  FontColor #1D231E
  FontName Helvetica
  FontSize 12
  BorderThickness 1.3
}
skinparam package {
  BackgroundColor #F1F6F0
  BorderColor #8FB89A
  FontColor #234D2E
  FontStyle bold
  FontSize 13
}
skinparam arrow {
  Color #6B4F26
  FontColor #6B4F26
  FontSize 10
  Thickness 1.2
}

title ElevConnect — Schéma relationnel v4 (MySQL 8 · InnoDB · utf8mb4)

package "Utilisateurs & rôles" #F1F6F0 {
  entity "UTILISATEURS" as UTIL {
    * id_utilisateur : INT <<PK>>
    --
    nom : VARCHAR(100)
    prenom : VARCHAR(100)
    email : VARCHAR(150) <<UQ>>
    mot_de_passe : VARCHAR(255)
    telephone : VARCHAR(20)
    adresse : VARCHAR(255)
    latitude : DECIMAL(10,7)
    longitude : DECIMAL(10,7)
    role : ENUM
    statut : ENUM
    date_inscription : DATETIME
  }
  entity "ELEVEURS" as ELE {
    * id_utilisateur : INT <<PK,FK>>
    --
    nom_exploitation : VARCHAR(150)
    certificat_chemin : VARCHAR(255)
    note_moyenne : DECIMAL(3,2)
    nombre_avis : INT
  }
  entity "ACHETEURS" as ACH {
    * id_utilisateur : INT <<PK,FK>>
    --
    type_acheteur : ENUM
  }
  entity "VENDEUR_PROVENDE" as VDP {
    * id_utilisateur : INT <<PK,FK>>
    --
    nom_boutique : VARCHAR(150)
    certificat_chemin : VARCHAR(255)
    note_moyenne : DECIMAL(3,2)
    nombre_avis : INT
  }
  entity "VENDEUR_ACCESSOIRE" as VDA {
    * id_utilisateur : INT <<PK,FK>>
    --
    nom_boutique : VARCHAR(150)
    certificat_chemin : VARCHAR(255)
    note_moyenne : DECIMAL(3,2)
    nombre_avis : INT
  }
  entity "VETERINAIRES" as VET {
    * id_utilisateur : INT <<PK,FK>>
    --
    specialite : VARCHAR(150)
    zone_intervention : VARCHAR(150)
    certificat_chemin : VARCHAR(255)
    note_moyenne : DECIMAL(3,2)
    nombre_avis : INT
  }
  entity "LIVREURS" as LIV {
    * id_utilisateur : INT <<PK,FK>>
    --
    moyen_transport : VARCHAR(100)
    zone_couverture : VARCHAR(150)
  }
  entity "ADMINISTRATEURS" as ADM {
    * id_utilisateur : INT <<PK,FK>>
  }
}

note bottom of UTIL
  latitude / longitude : coordonnées GPS communes
  à tous les rôles, portées une seule fois ici
  (aucune des 7 tables de profil ne les duplique)
end note

package "Annonces" #F1F6F0 {
  entity "ANNONCES" as ANN {
    * id_annonce : INT <<PK>>
    --
    id_utilisateur : INT <<FK>>
    type_annonce : ENUM
    titre : VARCHAR(150)
    description : TEXT
    prix_unitaire : DECIMAL(12,2)
    quantite : INT
    poids : DECIMAL(8,2)
    mois : SMALLINT
    unite_de_mesure : ENUM
    image_1 : VARCHAR(255)
    image_2 : VARCHAR(255)
    statut : ENUM
    motif_rejet : VARCHAR(255)
    etat : ENUM
    date_publication : DATETIME
  }
  entity "REDUCTIONS_ANNONCE" as RAN {
    * id_reduction : INT <<PK>>
    --
    id_annonce : INT <<FK>>
    quantite_min : INT
    quantite_max : INT
    pourcentage_reduction : DECIMAL(5,2)
  }
}

package "Commandes & paiements" #F1F6F0 {
  entity "COMMANDES" as CMD {
    * id_commande : INT <<PK>>
    --
    id_annonce : INT <<FK>>
    id_acheteur : INT <<FK>>
    quantite : INT
    prix_unitaire : DECIMAL(12,2)
    montant_total : DECIMAL(12,2)
    reduction_sur_commande : DECIMAL(12,2)
    montant_net_commande : DECIMAL(12,2)
    statut : ENUM
    motif_de_rejet : VARCHAR(255)
    description : TEXT
    note_client_commande : TINYINT
    avis_client_commande : TEXT
    code_authenticite : VARCHAR(64) <<UQ>>
    date_commande : DATETIME
  }
  entity "PAIEMENTS" as PAI {
    * id_paiement : INT <<PK>>
    --
    id_commande : INT <<FK,UQ>>
    montant_net_commande : DECIMAL(12,2)
    montant_net_livraison : DECIMAL(12,2)
    total_general : DECIMAL(12,2)
    moyen_de_paiement : ENUM
    numero_de_compte : VARCHAR(50)
    commission_sur_commande : DECIMAL(12,2)
    commission_sur_livraison : DECIMAL(12,2)
    total_commission : DECIMAL(12,2)
    montant_a_verser_au_fournisseur : DECIMAL(12,2)
    montant_a_verser_au_livreur : DECIMAL(12,2)
    statut_paiement : ENUM
    date_paiement : DATETIME
  }
}

package "Livraison" #F1F6F0 {
  entity "LIVRAISON" as LVR {
    * id_livraison : INT <<PK>>
    --
    id_commande : INT <<FK,UQ>>
    id_livreur : INT <<FK>>
    adresse_fournisseur : VARCHAR(255)
    adresse_client : VARCHAR(255)
    frais_de_livraison : DECIMAL(12,2)
    reduction_sur_frais : DECIMAL(12,2)
    montant_net_livraison : DECIMAL(12,2)
    statut : ENUM
    verification_authenticite : ENUM
    description : TEXT
    note_client_livraison : TINYINT
    avis_client_livraison : TEXT
  }
  entity "PLANNING_LIVREUR" as PLN {
    * id_planning : INT <<PK>>
    --
    id_livreur : INT <<FK>>
    date_debut : DATETIME
    date_fin : DATETIME
    disponible : BOOLEAN
  }
  entity "REDUCTIONS_LIVRAISON" as RLV {
    * id_reduction : INT <<PK>>
    --
    id_livreur : INT <<FK>>
    quantite_min : INT
    quantite_max : INT
    pourcentage_reduction : DECIMAL(5,2)
  }
}

note bottom of LVR
  Table alimentée uniquement si l'acheteur choisit
  la livraison à la commande ; en cas de retrait
  direct, aucune ligne LIVRAISON n'est créée et la
  vérification par QR code ne s'applique pas
end note

package "Versements" #F1F6F0 {
  entity "VERSEMENTS" as VER {
    * id_versement : INT <<PK>>
    --
    id_commande : INT <<FK>>
    id_paiement : INT <<FK>>
    type_beneficiaire : ENUM
    id_beneficiaire : INT <<FK>>
    montant_verser : DECIMAL(12,2)
    moyen_de_versement : ENUM
    numero_de_compte : VARCHAR(50)
    statut_versement : ENUM
    date_versement : DATETIME
  }
}

package "Vétérinaires" #F1F6F0 {
  entity "SERVICES_VETERINAIRES" as SRV {
    * id_service : INT <<PK>>
    --
    id_veterinaire : INT <<FK>>
    titre_service : VARCHAR(150)
    description : TEXT
    prix : DECIMAL(12,2)
    temps_traitement : SMALLINT
    photo_illustrative : VARCHAR(255)
    statut_service : ENUM
  }
  entity "RENDEZ_VOUS" as RDV {
    * id_rdv : INT <<PK>>
    --
    id_eleveur : INT <<FK>>
    id_veterinaire : INT <<FK>>
    id_service : INT <<FK>>
    sujet : VARCHAR(255)
    description : TEXT
    date_prevue : DATETIME
    statut : ENUM
    image_1 : VARCHAR(255)
    image_2 : VARCHAR(255)
    video : VARCHAR(255)
    note_client : TINYINT
    avis_client : TEXT
    date_creation : DATETIME
  }
  entity "ABONNEMENTS" as ABO {
    * id_abonnement : INT <<PK>>
    --
    id_veterinaire : INT <<FK>>
    formule : ENUM
    date_debut : DATE
    date_expiration : DATE
    statut : ENUM
  }
}

note bottom of ABO
  formule = basique (gratuite, attribuée par défaut)
  ou premium (payante, 2000 fcfa/mois)
end note

package "Communication" #F1F6F0 {
  entity "NOTIFICATIONS" as NOT {
    * id_notification : INT <<PK>>
    --
    id_utilisateur : INT <<FK>>
    contenu : VARCHAR(255)
    type : VARCHAR(50)
    lu : BOOLEAN
    date_creation : DATETIME
  }
}

package "Contenus éditoriaux" #F1F6F0 {
  entity "ACTUALITES" as ACT {
    * id_actualite : INT <<PK>>
    --
    id_auteur : INT <<FK>>
    titre : VARCHAR(200)
    contenu : TEXT
    date_publication : DATETIME
  }
  entity "ACTUALITES_MEDIA" as ACM {
    * id_media : INT <<PK>>
    --
    id_actualite : INT <<FK>>
    chemin_fichier : VARCHAR(255)
    type_media : ENUM
  }
}

' ---------------- Relations : rôles (table par sous-type) ----------------
UTIL ||--o| ELE
UTIL ||--o| ACH
UTIL ||--o| VDP
UTIL ||--o| VDA
UTIL ||--o| VET
UTIL ||--o| LIV
UTIL ||--o| ADM

' ---------------- Annonces ----------------
UTIL ||--o{ ANN : id_utilisateur (fournisseur)
ANN  ||--o{ RAN

' ---------------- Commandes & paiements ----------------
ANN  ||--o{ CMD
UTIL ||--o{ CMD : id_acheteur
CMD  ||--o| PAI

' ---------------- Livraison ----------------
CMD  ||--o| LVR
LIV  |o--o{ LVR : id_livreur
LIV  ||--o{ PLN
LIV  ||--o{ RLV

' ---------------- Versements ----------------
CMD  ||--o{ VER
PAI  ||--o{ VER
UTIL ||--o{ VER : id_beneficiaire

' ---------------- Vétérinaires ----------------
VET  ||--o{ SRV
ELE  ||--o{ RDV : id_eleveur
VET  ||--o{ RDV : id_veterinaire
SRV  |o--o{ RDV : id_service
VET  ||--o{ ABO

' ---------------- Communication ----------------
UTIL ||--o{ NOT

' ---------------- Éditorial ----------------
UTIL ||--o{ ACT : "auteur\n(rôle ≠ acheteur)"
ACT  ||--o{ ACM

legend right
  |= Symbole |= Signification |
  | <<PK>> | Clé primaire |
  | <<FK>> | Clé étrangère |
  | <<UQ>> | Contrainte unique |
  | ||--o{ | 1,1 — 0,n |
  | |o--o{ | 0,1 — 0,n |
  | ||--o| | 1,1 — 0,1 |
endlegend
@enduml
