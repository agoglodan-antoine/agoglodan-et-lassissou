@startuml schema_relationnel
!include diagram_style.iuml

top to bottom direction
title Schéma relationnel — tables principales

package "Utilisateurs" {
  entity "UTILISATEURS" as USER {
    * id_utilisateur <<PK>>
    --
    email <<UQ>>
    role
    statut
  }
}

package "Catalogue" {
  entity "ANNONCES" as ANN {
    * id_annonce <<PK>>
    --
    id_utilisateur <<FK>>
    prix_unitaire
    quantite
    statut
  }
  entity "REDUCTIONS_ANNONCE" as RED {
    * id_reduction <<PK>>
    --
    id_annonce <<FK>>
    quantite_min
    pourcentage
  }
}

package "Vente & livraison" {
  entity "COMMANDES" as CMD {
    * id_commande <<PK>>
    --
    id_annonce <<FK>>
    id_acheteur <<FK>>
    montant_net
    mode_retrait
    statut
  }
  entity "PAIEMENTS" as PAY {
    * id_paiement <<PK>>
    --
    id_commande <<FK, UQ>>
    total_general
    statut
  }
  entity "LIVRAISONS" as DEL {
    * id_livraison <<PK>>
    --
    id_commande <<FK, UQ>>
    id_livreur <<FK>>
    statut
    verification_qr
  }
  entity "VERSEMENTS" as SETTLE {
    * id_versement <<PK>>
    --
    id_paiement <<FK>>
    id_beneficiaire <<FK>>
    montant
    statut
  }
}

package "Services vétérinaires" {
  entity "SERVICES_VETERINAIRES" as SERVICE {
    * id_service <<PK>>
    --
    id_veterinaire <<FK>>
    titre
    prix
  }
  entity "RENDEZ_VOUS" as APPT {
    * id_rdv <<PK>>
    --
    id_service <<FK>>
    id_eleveur <<FK>>
    date_prevue
    statut
  }
}

package "Communication" {
  entity "NOTIFICATIONS" as NOTIF {
    * id_notification <<PK>>
    --
    id_utilisateur <<FK>>
    contenu
    lu
  }
}

USER ||--o{ ANN : publie
ANN ||--o{ RED : applique
USER ||--o{ CMD : passe
ANN ||--o{ CMD : concerne
CMD ||--o| PAY : règle
CMD ||--o| DEL : livraison optionnelle
USER |o--o{ DEL : livre
PAY ||--o{ SETTLE : déclenche
USER ||--o{ SETTLE : reçoit
USER ||--o{ SERVICE : propose
SERVICE ||--o{ APPT : concerne
USER ||--o{ APPT : demande
USER ||--o{ NOTIF : reçoit

legend right
  |= Abréviation |= Signification |
  | PK | clé primaire |
  | FK | clé étrangère |
  | UQ | valeur unique |
endlegend
@enduml
