@startuml state_annonce
' Diagramme d'état manquant : cycle de vie d'une ANNONCE
' (modération administrateur — instructions.txt, section II-b)

[*] --> en_attente : le fournisseur publie l'annonce

en_attente --> visible : l'administrateur approuve
en_attente --> rejetee : l'administrateur désapprouve\n(motif renseigné)

visible --> [*]
rejetee --> [*]

state en_attente as "en attente"
state visible as "visible"
state rejetee as "rejetee"

note right of visible
  Une notification est envoyée au fournisseur :
  « votre annonce est approuvée et désormais
  visible sur ElevConnect »
end note
note right of rejetee
  Une notification est envoyée au fournisseur :
  « votre annonce a été rejetée pour faute de ... »
end note

state "Disponibilité commerciale (etat)" as ETAT {
  [*] --> disponible
  disponible --> stock_epuise : quantité écoulée
  stock_epuise --> disponible : réapprovisionnement
  state disponible as "disponible"
  state stock_epuise as "stock épuisé"
}
visible --> ETAT : dès que l'annonce est visible
@enduml
