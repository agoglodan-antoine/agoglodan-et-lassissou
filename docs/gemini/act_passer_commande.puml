title Passer une commande

|Client|
start
:Choisir une annonce,
une quantité et le mode de retrait;
|Système ElevConnect|
if (Client propriétaire de l'annonce ?) then (oui)
  :Bloquer la commande
et informer le client;
  stop
else (non)
  :Vérifier le stock et
calculer le montant;
  if (Stock disponible ?) then (oui)
    :Créer la commande et
le code QR d'authenticité;
    |Client|
    :Payer la commande;
    |Fournisseur|
    :Accepter ou refuser
la commande;
    if (Commande acceptée ?) then (oui)
      |Système ElevConnect|
      if (Livraison choisie ?) then (oui)
        :Proposer la livraison
à un livreur disponible;
        |Livreur|
        :Livrer la commande
et présenter le QR code;
        |Client|
        :Scanner le QR code et
confirmer la réception;
      else (retrait direct)
        |Client|
        :Confirmer la réception
chez le fournisseur;
      endif
      |Système ElevConnect|
      :Confirmer la commande et
verser les bénéficiaires;
      stop
    else (non)
      |Système ElevConnect|
      :Refuser la commande et
rembourser le client;
      stop
    endif
  else (non)
    :Informer le client que
le stock est indisponible;
    stop
  endif
endif
@enduml