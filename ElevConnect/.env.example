APP_NAME=ElevConnect
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Africa/Porto-Novo
APP_LOCALE=fr

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Base de données — nommage aligné sur ElevConnect_schema_bdd_v4.sql,
# environnement local WampServer (cf. mémoire, chap. 4 "Environnement de développement").
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=elevconnect
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_FROM_ADDRESS="contact@elevconnect.bj"
MAIL_FROM_NAME="${APP_NAME}"
